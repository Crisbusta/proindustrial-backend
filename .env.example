# ── App ──────────────────────────────────────────────────
APP_ENV=development          # development | production

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/proindustrial?sslmode=disable

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-secret    # REQUIRED in production

# ── Server ───────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=http://localhost:3001
APP_BASE_URL=http://localhost:3001

# ── Initial provider password (admin panel) ──────────────
INITIAL_PASSWORD=           # if empty, a random 12-char password is generated per approval

# ── Email — Resend (preferred) ───────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# ── Email — SMTP fallback ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Storage ──────────────────────────────────────────────
STORAGE_DRIVER=local           # local | s3
STORAGE_DIR=./uploads          # local only: directory for uploaded files

# S3 / Cloudflare R2 (only needed when STORAGE_DRIVER=s3)
# For R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#         S3_REGION=auto
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE=                # e.g. https://cdn.proindustrial.cl
