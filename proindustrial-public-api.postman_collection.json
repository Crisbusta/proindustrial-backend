{
  "info": {
    "name": "ProIndustrial Public API",
    "description": "Complete Postman collection for the current ProIndustrial public backend: public catalog, provider auth and panel, password bootstrap, admin auth, and registration approval flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "provider_jwt_token", "value": "", "type": "string" },
    { "key": "admin_jwt_token", "value": "", "type": "string" },
    { "key": "registration_id", "value": "", "type": "string" },
    { "key": "service_id", "value": "", "type": "string" },
    { "key": "quote_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "List category groups",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/category-groups",
            "description": "Returns the category tree used by the public frontend."
          }
        },
        {
          "name": "List regions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/regions"
          }
        },
        {
          "name": "List all companies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/companies"
          }
        },
        {
          "name": "Filter companies by category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies?category=termofusion",
              "host": ["{{base_url}}"],
              "path": ["api", "companies"],
              "query": [{ "key": "category", "value": "termofusion" }]
            }
          }
        },
        {
          "name": "Filter companies by region",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies?region=Antofagasta",
              "host": ["{{base_url}}"],
              "path": ["api", "companies"],
              "query": [{ "key": "region", "value": "Antofagasta" }]
            }
          }
        },
        {
          "name": "Filter featured companies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/companies?featured=true",
              "host": ["{{base_url}}"],
              "path": ["api", "companies"],
              "query": [{ "key": "featured", "value": "true" }]
            }
          }
        },
        {
          "name": "Get company by slug",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/companies/proveedora-aceros-pacifico"
          }
        },
        {
          "name": "Submit quote request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/quotes",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requesterName\": \"Juan Pérez\",\n  \"requesterCompany\": \"Minera Ejemplo\",\n  \"requesterEmail\": \"juan@ejemplo.cl\",\n  \"requesterPhone\": \"+56 9 1234 5678\",\n  \"service\": \"Termofusión PEAD\",\n  \"description\": \"Necesitamos instalar 500m de tubería PEAD DN160 para riego.\",\n  \"location\": \"Antofagasta\",\n  \"targetCompanyId\": \"\"\n}"
            }
          }
        },
        {
          "name": "Register provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const id = res?.data?.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('registration_id', id);",
                  "  console.log('registration_id saved:', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/registrations",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Nueva Empresa SpA\",\n  \"email\": \"contacto@nuevaempresa.cl\",\n  \"phone\": \"+56 9 8765 4321\",\n  \"region\": \"Antofagasta\",\n  \"services\": [\"termofusion\"],\n  \"description\": \"Empresa con 10 años de experiencia en termofusión.\"\n}"
            },
            "description": "Creates a pending provider registration and saves {{registration_id}}."
          }
        }
      ]
    },
    {
      "name": "Provider Auth",
      "item": [
        {
          "name": "Login provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('provider_jwt_token', res.token);",
                  "  console.log('Provider JWT token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contacto@acerospacifico.cl\",\n  \"password\": \"demo123\"\n}"
            },
            "description": "Logs in a provider and saves {{provider_jwt_token}}."
          }
        },
        {
          "name": "Get current provider (me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "Change provider password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"demo123\",\n  \"newPassword\": \"demo12345\"\n}"
            },
            "description": "For newly approved providers, replaces the bootstrap password."
          }
        }
      ]
    },
    {
      "name": "Panel",
      "description": "All provider panel requests require Bearer {{provider_jwt_token}}.",
      "item": [
        {
          "name": "Dashboard stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/panel/dashboard/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "List quotes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/panel/quotes",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "List quotes by status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/panel/quotes?status=new",
              "host": ["{{base_url}}"],
              "path": ["api", "panel", "quotes"],
              "query": [{ "key": "status", "value": "new" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "Update quote status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/panel/quotes/{{quote_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"read\"\n}"
            },
            "description": "Set {{quote_id}} first. Allowed statuses: new, read, responded."
          }
        },
        {
          "name": "List services",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/panel/services",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "Create service",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const id = res?.data?.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('service_id', id);",
                  "  console.log('service_id saved:', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/panel/services",
            "header": [
              { "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inspección de soldaduras\",\n  \"category\": \"termofusion\",\n  \"description\": \"Inspección visual y ensayo de hermeticidad de uniones termofundidas.\"\n}"
            },
            "description": "Creates a service and saves {{service_id}}."
          }
        },
        {
          "name": "Update service",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/panel/services/{{service_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inspección de soldaduras actualizada\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Delete service",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/panel/services/{{service_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/panel/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" }]
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/panel/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{provider_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tagline\": \"Especialistas en termofusión y tuberías PEAD\",\n  \"phone\": \"+56 55 234 5678\",\n  \"website\": \"https://acerospacifico.cl\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('admin_jwt_token', res.token);",
                  "  console.log('Admin JWT token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@proindustrial.local\",\n  \"password\": \"demo123\"\n}"
            },
            "description": "Logs in the admin user and saves {{admin_jwt_token}}."
          }
        },
        {
          "name": "Get current admin (me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin Registrations",
      "description": "All requests require Bearer {{admin_jwt_token}}.",
      "item": [
        {
          "name": "List all registrations",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/registrations",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }]
          }
        },
        {
          "name": "List pending registrations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/registrations?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "registrations"],
              "query": [{ "key": "status", "value": "pending" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }]
          }
        },
        {
          "name": "Get registration by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/admin/registrations/{{registration_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }],
            "description": "Set {{registration_id}} first, or use the Register provider request which saves it automatically."
          }
        },
        {
          "name": "Approve registration",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/registrations/{{registration_id}}/approve",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }],
            "description": "Approves the pending registration, creates company + provider user, and returns email delivery status."
          }
        },
        {
          "name": "Reject registration",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/registrations/{{registration_id}}/reject",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }]
          }
        }
      ]
    }
  ]
}
